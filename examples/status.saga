module RataExample.Status

import Rata.Fetch as Fetch
import Rata.Fetch.Httpc as Httpc

main () = {
  case Fetch.get "https://example.com/missing" {
    Ok response -> case Fetch.expect_success response {
      Ok successful -> dbg successful.status
      Err status_error -> dbg status_error
    }
    Err error -> dbg error
  }
} with Httpc.httpc
